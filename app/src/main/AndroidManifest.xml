<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 오버레이 권한 (가짜 전화 화면 표시) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- 진동 -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- 포그라운드 서비스 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- 실제 전화 감지 -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <!-- 연락처 검색 -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- 알림 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 화면 켜짐 유지 (흔들기 감지) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- 포그라운드 서비스 타입: specialUse (센서 감지) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- 포그라운드 서비스 타입: mediaPlayback (ButtonWatchService 의 MediaSession 볼륨 라우팅용) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- 배터리 최적화 제외 요청 (백그라운드 서비스가 Doze 모드에서도 살아있도록) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- 인터넷 (Clarity 분석, 크래시 리포트) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!--
      v1.5.8 — GPS 지오펜스 권한 제거.
      v1.4.0 에 추가된 GeofenceManager 코드는 호출하는 곳이 없는 dead code 였고,
      Play Console 비공개 테스트 검토에서 "선언되지 않은 민감한 권한" 오류 유발.
      향후 지오펜스 시나리오 재도입 시 이 권한 + 정당화 양식을 다시 추가할 것.
    -->
    <!-- <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" /> -->
    <!-- <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" /> -->

    <application
        android:name=".EjectApplication"
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EjectButton">

        <!-- AdMob App ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3230287048532628~3824645265" />

        <!--
          AD_SERVICES_CONFIG 충돌 해결 (Round 16).
          play-services-measurement-api (Firebase Analytics) 는 ga_ad_services_config,
          play-services-ads-lite (AdMob) 는 gma_ad_services_config 를 같은 속성명으로
          선언한다. 둘 다 Privacy Sandbox Topics API 를 설정하는 메타데이터이므로
          기능적으로 호환되며, 여기서는 AdMob 쪽(gma_*) 을 명시적으로 채택해
          manifest merger 충돌을 해소한다.
        -->
        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />

        <!--
          v1.1.0 — 위장 아이콘 (decoy launcher).
          기본 launcher (.MainActivity) 외에 4개 alias 추가.
          가정폭력 / 강요 환경에서 폰을 옆 사람이 봐도 "Eject Button" 이름이
          노출 안 되도록 위장. 사용자는 설정 화면에서 활성 alias 를 선택,
          코드에서 PackageManager.setComponentEnabledSetting() 으로 토글.
          - .Calculator  : 일반 계산기로 위장
          - .Memo        : 메모장으로 위장
          - .Weather     : 날씨 앱으로 위장
          - .Clock       : 시계 앱으로 위장
          기본은 MainActivity (활성), alias 4개는 disabled 상태로 시작.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:showOnLockScreen="true"
            android:turnScreenOn="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 위장 아이콘 1: 계산기 -->
        <activity-alias
            android:name=".launcher.Calculator"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/decoy_label_calculator">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 위장 아이콘 2: 메모장 -->
        <activity-alias
            android:name=".launcher.Memo"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/decoy_label_memo">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 위장 아이콘 3: 날씨 -->
        <activity-alias
            android:name=".launcher.Weather"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/decoy_label_weather">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 위장 아이콘 4: 시계 -->
        <activity-alias
            android:name=".launcher.Clock"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/decoy_label_clock">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <service
            android:name=".service.FakeCallOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="fake_call_simulation" />
        </service>

        <service
            android:name=".service.ShakeDetectionService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <!-- Round 28 — required by Play policy for every specialUse FGS on
                 API 34+: name the subtype so the Play Console declaration can
                 reference it. Justification for Play Console → Advanced
                 settings → Foreground services: "Detects user-configured shake
                 gesture while the screen is off to deliver a scheduled fake
                 call; no other shake/accelerometer API can run in Doze." -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="shake_gesture_pattern_detection" />
        </service>

        <!--
          v1.4.0 — Geofence 이벤트 수신 BroadcastReceiver.
          PendingIntent 으로 GeofencingClient 에 등록되며, OS 가 지오펜스 진입/이탈 감지
          시 이 receiver 의 onReceive 호출. 백그라운드에서도 작동 (FOREGROUND_SERVICE
          따로 필요 X — OS 가 효율적으로 wake up 시킴).
        -->
        <receiver
            android:name=".geofence.GeofenceTransitionReceiver"
            android:exported="false" />

        <service
            android:name=".service.ButtonWatchService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback|specialUse">
            <!-- mediaPlayback: 화면 OFF 상태에서도 볼륨 키를 MediaSession 으로 라우팅받아야 하므로 필수. -->
            <!-- specialUse: hardware_button_pattern_detection 서브타입도 유지. -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="hardware_button_pattern_detection" />
            <!-- MediaSession 이 media button 이벤트를 수신할 수 있는 진입점 -->
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </service>

    </application>

</manifest>
