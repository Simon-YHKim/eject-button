<!--
  rec_icon_green.xml

  Cassette mini-glyph for the recording tile. White strokes/fills are
  overridden by Icon(tint = RecGreen) in the composable, so the whole
  mark renders as a single green color.

  Derived from the simplified reference SVG (no T stem, two filled
  reels, short tape line):

    <svg viewBox="0 0 24 24" stroke="#22C55E" stroke-width="1.8">
      <rect x="3" y="6" width="18" height="12" rx="2"/>
      <circle cx="8"  cy="12" r="2" fill="#22C55E"/>
      <circle cx="16" cy="12" r="2" fill="#22C55E"/>
      <line x1="10" y1="12" x2="14" y2="12"/>
    </svg>
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Cassette body (rounded rect, stroke only, rx = 2) -->
    <path
        android:pathData="M5,6 L19,6 A2,2 0 0 1 21,8 L21,16 A2,2 0 0 1 19,18 L5,18 A2,2 0 0 1 3,16 L3,8 A2,2 0 0 1 5,6 Z"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineJoin="round" />

    <!-- Left reel (filled) -->
    <path
        android:pathData="M10,12 A2,2 0 1 1 6,12 A2,2 0 1 1 10,12 Z"
        android:fillColor="#FFFFFF" />

    <!-- Right reel (filled) -->
    <path
        android:pathData="M18,12 A2,2 0 1 1 14,12 A2,2 0 1 1 18,12 Z"
        android:fillColor="#FFFFFF" />

    <!-- Tape line between reels -->
    <path
        android:pathData="M10,12 L14,12"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />
</vector>
