<?xml version="1.0" encoding="utf-8"?>
<!--
    Eject Button 런처 아이콘 전경 — v1.6.0 Navy + Cream 브랜드.
    흰색 픽토그램: 도망치는 사람(휴대폰을 귀에 대고 달리는) + 말풍선/문.
    Adaptive icon 안전 영역 (중앙 72dp / viewport 108dp) 안에 배치.
    monochrome 슬롯 호환을 위해 모두 흰색 단색.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ===== 1. 말풍선/문 (사람 뒤 배경) =====
         사람을 감싸는 큰 흰색 직사각형. 우상단 약간 떨어진 듯한 형태로,
         오른쪽 아래로 갈수록 살짝 좁아져 "문이 열린" 또는 "speech bubble"
         느낌을 동시 연출. -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M30,28 L78,30 L80,82 L28,80 Z" />

    <!-- ===== 2. 사람 머리 (오른쪽으로 달리는 자세) ===== -->
    <path
        android:fillColor="#1B2D4A"
        android:pathData="M62,40 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0" />

    <!-- ===== 3. 사람 몸통 + 휴대폰 든 왼팔(귀에 댄 자세) =====
         단순화: 몸통 + 휴대폰 잡은 팔을 한 path 로. 휴대폰은 작은 사각형. -->
    <!-- 몸통 (어깨~허리) -->
    <path
        android:fillColor="#1B2D4A"
        android:pathData="M56,48 L66,48 L68,62 L54,62 Z" />

    <!-- 휴대폰 잡은 팔 + 휴대폰 (귀 쪽으로) -->
    <path
        android:fillColor="#1B2D4A"
        android:pathData="M62,46 L66,42 L67,40 L64,38 L62,40 Z M63,36 L66,33 L70,35 L68,38 Z" />

    <!-- 뒤로 흔드는 오른팔 (달리는 자세) -->
    <path
        android:fillColor="#1B2D4A"
        android:pathData="M56,50 L52,54 L50,58 L48,55 L52,50 Z" />

    <!-- ===== 4. 다리 (달리는 자세: 한 다리 앞, 한 다리 뒤) ===== -->
    <!-- 앞 다리 (오른쪽 무릎 굽힘) -->
    <path
        android:fillColor="#1B2D4A"
        android:pathData="M64,62 L70,68 L73,72 L70,74 L66,69 L62,64 Z" />
    <!-- 뒷 다리 (왼쪽 뒤로 뻗음) -->
    <path
        android:fillColor="#1B2D4A"
        android:pathData="M56,62 L52,68 L48,72 L51,74 L55,69 L59,64 Z" />

    <!-- ===== 5. 휴대폰 신호 arcs (휴대폰 위쪽) ===== -->
    <!-- 작은 호 (안쪽) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M70,32 a4,4 0 0,1 4,-4 L72,30 a2,2 0 0,0 -2,2 Z" />
    <!-- 큰 호 (바깥쪽) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M70,28 a7,7 0 0,1 7,-7 L75,23 a5,5 0 0,0 -5,5 Z" />

</vector>
