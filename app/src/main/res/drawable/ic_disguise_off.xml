<?xml version="1.0" encoding="utf-8"?>
<!--
    v1.5.17 — 사용자가 제공한 Dedcoy.png 디자인을 5 density raster mipmap
    (drawable-{m,h,xh,xxh,xxxh}dpi/ic_disguise.png) 으로 변환한 뒤 그 raster
    를 BitmapDrawable 로 wrap 한다. 기존 vector (가면 + ⏏ glyph) 는 폐기.

    Normal state (위장 안 함) = full opacity. ON state 와의 시각 차이는
    IconButton 의 selected 표시 또는 색 tint 로 처리 (코드 측 후속 작업).
    일단 디자인 자체는 두 state 동일 (사용자 요청 "디코이 아이콘 변경").
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@drawable/ic_disguise"
    android:gravity="center" />
