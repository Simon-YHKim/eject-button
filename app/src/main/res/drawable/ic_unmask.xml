<!--
  ic_unmask · v1.5.11 · TopAppBar action icon (위장 복구)
  Design: handoff-unmask/preview-v2.html — V1 (DEFAULT, PICK)
  컨셉: 메인 EJECT 버튼과 동일 톤 (deep red #A82430) 의 베네치아 가면 + 잉크 (#1A1A1A) 의 ⏏ 글리프.
  위장 모드 (계산기/메모/날씨/시계) 에서만 TopAppBar 에 노출되는 action 아이콘이며,
  탭 시 DecoyManager.setActive(ctx, Decoy.DEFAULT) 로 원래 launcher (Eject Button) 복구.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Eject glyph (top): solid fill triangle + horizontal bar (메인 EJECT 버튼과 동일 비율) -->
    <path
        android:pathData="M9,6.6 L12,3.6 L15,6.6 Z"
        android:fillColor="#1A1A1A" />
    <path
        android:pathData="M9,8.2 L15,8.2"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />

    <!-- Falling Venetian mask, tilted -10° around (12,16), translated (+0.4,+0.4) -->
    <group
        android:pivotX="12"
        android:pivotY="16"
        android:rotation="-10"
        android:translateX="0.4"
        android:translateY="0.4">

        <!-- 가면 본체: 가로 띠 + 코 부분 V 컷 + 양 끝 살짝 솟음 (베네치아 마스크) -->
        <path
            android:pathData="M3.6,14.4 C3.6,13.4 4.4,12.6 5.4,12.6 L9.4,12.6 L11.2,11.6 C11.7,11.3 12.3,11.3 12.8,11.6 L14.6,12.6 L18.6,12.6 C19.6,12.6 20.4,13.4 20.4,14.4 L20.4,15.6 C20.4,17.4 19,18.8 17.2,18.8 L6.8,18.8 C5,18.8 3.6,17.4 3.6,15.6 Z"
            android:fillColor="#A82430" />

        <!-- 왼쪽 눈 슬릿 (아몬드 형태) -->
        <path
            android:pathData="M6.8,14.6 C7.6,14 9.0,14 9.8,14.6 C9.0,15.4 7.6,15.4 6.8,14.6 Z"
            android:fillColor="#FFFFFF" />

        <!-- 오른쪽 눈 슬릿 -->
        <path
            android:pathData="M14.2,14.6 C15.0,14 16.4,14 17.2,14.6 C16.4,15.4 15.0,15.4 14.2,14.6 Z"
            android:fillColor="#FFFFFF" />
    </group>
</vector>
