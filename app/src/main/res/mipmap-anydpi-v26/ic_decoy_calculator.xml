<?xml version="1.0" encoding="utf-8"?>
<!--
    v1.5.16 - Decoy_Calculator user-provided raster (1024px PNG) applied across
    5 density mipmap. Background kept as solid color (decoy concept), foreground
    is the new raster pictogram. monochrome shares the same raster so Android 13+
    themed icon mode grayscales it consistently with the launcher icon.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_decoy_calculator_bg"/>
    <foreground android:drawable="@mipmap/ic_decoy_calculator_foreground"/>
    <monochrome android:drawable="@mipmap/ic_decoy_calculator_foreground"/>
</adaptive-icon>
