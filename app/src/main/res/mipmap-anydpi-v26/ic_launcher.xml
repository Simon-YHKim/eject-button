<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon. The <monochrome> slot (Android 13+) lets the
  system tint/mask the icon to match the user's Material You palette.
  The ⏏ foreground is already a solid white glyph so we can reuse it —
  the system ignores its color and applies its own tint.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background"/>
    <foreground android:drawable="@drawable/ic_launcher_foreground"/>
    <monochrome android:drawable="@drawable/ic_launcher_foreground"/>
</adaptive-icon>
