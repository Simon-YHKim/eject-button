<?xml version="1.0" encoding="utf-8"?>
<!--
    Eject Button v1.5.14 - Android 12+ system splash screen overrides.

    Without an explicit windowSplashScreen* declaration the Android 12+ system
    splash screen falls back to the adaptive launcher icon foreground PNG at
    its raw drawable bounds. With cached APK state on the device or on some
    OEM launchers, this can render the previous (pre-v1.5.13) icon revision
    or an off-center crop of the new icon - exactly the symptom reported as
    "old icon still on loading screen".

    Fix: pin the splash icon explicitly to @mipmap/ic_launcher (the v1.5.13
    adaptive icon XML, which references the new foreground/background
    drawables) and brand the splash background with EmergencyRed so the
    transition into Theme.EjectButton reads as "brand splash to app content"
    rather than as an OEM default flash.

    minSdk = 26 -> this v31 (API 31, Android 12) qualifier is the correct
    cutoff. On API 26..30 the OS has no system splash screen so the base
    values/themes.xml definition continues to apply unchanged.
-->
<resources>
    <style name="Theme.EjectButton" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Android 12+ system splash screen attributes. -->
        <!-- @mipmap/ic_launcher is the adaptive icon XML; the platform extracts
             foreground+background and applies the system splash mask. -->
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#B71720</item>
        <item name="android:windowSplashScreenBackground">#B71720</item>
    </style>
</resources>
