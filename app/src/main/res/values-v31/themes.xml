<?xml version="1.0" encoding="utf-8"?>
<!--
    Eject Button v1.5.17 - Android 12+ system splash screen overrides.

    History:
    - v1.5.14 first introduced this v31 override to pin splash icon and fix
      "old icon on loading screen" regression (windowSplashScreen* attrs missing
      in base themes.xml -> Android 12+ fell back to adaptive icon foreground PNG
      at raw bounds with potential edge cropping).
    - v1.5.17 (this revision): user reported the new launcher art is still being
      cropped on the system splash. Switching from @mipmap/ic_launcher (adaptive
      icon XML at full size) to @drawable/ic_splash_logo (ic_launcher_foreground
      wrapped in a 25% inset) guarantees the glyph sits inside the 192dp splash
      safe area.

    minSdk = 26 -> v31 (API 31, Android 12) qualifier is the correct cutoff.
    On API 26..30 the OS has no system splash; the base values/themes.xml
    definition applies unchanged.
-->
<resources>
    <style name="Theme.EjectButton" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Android 12+ system splash screen attributes. -->
        <!-- v1.5.17 — @drawable/ic_splash_logo wraps ic_launcher_foreground in
             a 25% inset so the glyph fits within the 192dp splash safe area.
             Previously @mipmap/ic_launcher (adaptive icon at full size)
             caused edge cropping because adaptive foreground fills the 108dp
             canvas without internal margin. -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#B71720</item>
        <item name="android:windowSplashScreenBackground">#B71720</item>
    </style>
</resources>
