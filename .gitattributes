# v1.5.21 — Normalize line endings across Windows / Linux / macOS commits.
#
# Why this file exists:
#   FakeCallOverlayService.kt got committed once with CRLF line endings on
#   Windows while the rest of the tree was LF, causing a phantom diff of
#   1,125 lines with no real semantic change. .gitattributes tells git to
#   normalize text files to LF in the repo and re-checkout with the
#   platform-native EOL via core.autocrlf — so cross-platform commits no
#   longer churn the diff.
#
# Rule of thumb:
#   * text=auto      → git decides text vs binary, normalize text → LF
#   * eol=lf         → force LF on commit AND on checkout (scripts/build)
#   * -text / binary → never touch (raster, archives, signed artifacts)

# Default: let git auto-detect, normalize text to LF in repo
* text=auto eol=lf

# Source code — always LF
*.kt           text eol=lf
*.kts          text eol=lf
*.java         text eol=lf
*.xml          text eol=lf
*.json         text eol=lf
*.jsonc        text eol=lf
*.md           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.toml         text eol=lf
*.gradle       text eol=lf
*.properties   text eol=lf
*.txt          text eol=lf
*.html         text eol=lf
*.css          text eol=lf
*.js           text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# Shell / build scripts — LF (executables on *nix)
*.sh           text eol=lf
gradlew        text eol=lf
Makefile       text eol=lf

# Windows-only scripts — CRLF
*.bat          text eol=crlf
*.cmd          text eol=crlf
*.ps1          text eol=crlf
gradlew.bat    text eol=crlf

# Binary — never normalize
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.webp         binary
*.ico          binary
*.pdf          binary
*.zip          binary
*.jar          binary
*.aar          binary
*.apk          binary
*.aab          binary
*.keystore     binary
*.jks          binary
*.so           binary
*.dex          binary
*.ttf          binary
*.otf          binary
*.woff         binary
*.woff2        binary
*.ai           binary
